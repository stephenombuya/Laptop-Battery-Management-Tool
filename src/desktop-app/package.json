{
  "name": "batteryos",
  "version": "2.0.0",
  "description": "BatteryOS — Intelligent Laptop Battery Manager",
  "author": "Stephen Ombuya",
  "license": "MIT",
  "main": "src/main.js",
  "homepage": "https://github.com/stephenombuya/Laptop-Battery-Management-Tool",
  "scripts": {
    "start":     "electron .",
    "dev":       "NODE_ENV=development electron .",
    "build":     "webpack --config webpack.config.js && electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux":"electron-builder --linux",
    "lint":      "eslint src/",
    "test":      "jest"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron":         "^30.0.0",
    "electron-builder": "^24.0.0",
    "webpack":          "^5.91.0",
    "webpack-cli":      "^5.1.4",
    "eslint":           "^9.0.0",
    "jest":             "^29.0.0"
  },
  "build": {
    "appId":       "com.batteryos.app",
    "productName": "BatteryOS",
    "icon":        "assets/icon",
    "files": [
      "src/**/*",
      "assets/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../../core-service",
        "to":   "core-service",
        "filter": ["**/*", "!__pycache__", "!*.pyc"]
      }
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon":   "assets/icon.ico"
    },
    "mac": {
      "target":   ["dmg", "zip"],
      "icon":     "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target":   ["AppImage", "deb"],
      "icon":     "assets/icon.png",
      "category": "Utility"
    }
  }
}
